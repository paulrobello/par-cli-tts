# TTS Provider API Keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Default TTS provider (elevenlabs, openai)
TTS_PROVIDER=elevenlabs

# Optional: Default voice settings
# For ElevenLabs (can be voice name or ID):
# ELEVENLABS_VOICE_ID=Rachel
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID=

# For OpenAI (alloy, echo, fable, onyx, nova, shimmer):
# OPENAI_VOICE_ID=nova
OPENAI_VOICE_ID=

# General voice ID (overrides provider-specific):
TTS_VOICE_ID=
